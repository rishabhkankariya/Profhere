rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        request.auth.uid == userId
        || request.auth.token.email.matches('.*admin.*')
      );
      allow delete: if isSignedIn()
        && request.auth.token.email.matches('.*admin.*');
    }

    // ── Faculty ────────────────────────────────────────────────────────────
    match /faculty/{facultyId} {
      allow read:   if true;
      allow create, delete: if isSignedIn()
        && request.auth.token.email.matches('.*admin.*');
      allow update: if isSignedIn();
    }

    // ── Events ────────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // ── Consultations ──────────────────────────────────────────────────────
    match /consultations/{queueId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false;
    }

    // ── Timetable ──────────────────────────────────────────────────────────
    match /timetable/{entryId} {
      allow read:              if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // ── Subjects ───────────────────────────────────────────────────────────
    match /subjects/{subjectId} {
      allow read:              if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // ── Marks ─────────────────────────────────────────────────────────────
    match /marks/{markId} {
      allow read:              if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // ── Community ─────────────────────────────────────────────────────────
    match /community/{messageId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /community_blocks/{userId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn();
    }

    match /community_restrictions/{userId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn();
    }

    // ── Todos ─────────────────────────────────────────────────────────────
    match /todos/{todoId} {
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.userId;
      allow read, update, delete: if isSignedIn()
        && request.auth.uid == resource.data.userId;
    }

    // ── Cabins ─────────────────────────────────────────────────────────────
    match /cabins/{cabinId} {
      allow read:  if true;
      allow write: if isSignedIn();
    }

    // ── Blocked users ──────────────────────────────────────────────────────
    match /blocked_users/{userId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn();
    }

    // ── Activity logs ──────────────────────────────────────────────────────
    match /activity_logs/{logId} {
      allow read, write: if isSignedIn();
    }

    // ── College students ───────────────────────────────────────────────────
    match /college_students/{docId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn()
        && request.auth.token.email.matches('.*admin.*');
    }

    // ── Class divisions ────────────────────────────────────────────────────
    match /class_divisions/{divisionId} {
      allow read:              if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // ── Location Access ────────────────────────────────────────────────────
    // Students can create requests and read their own requests
    // Faculty can read requests for them and update them (approve/reject/revoke)
    // NodeMCU can read to check for pending requests
    match /location_access/{accessId} {
      allow create: if isSignedIn();
      allow read: if true;  // Allow NodeMCU to read for request check
      allow update: if isSignedIn() && 
                       resource.data.facultyId == request.auth.uid;
      allow delete: if isSignedIn() && 
                       resource.data.facultyId == request.auth.uid;
    }

    // ── Faculty Locations ──────────────────────────────────────────────────
    // Faculty can write their own location (authenticated only)
    // Students with approved access can read (authenticated only)
    // NodeMCU can read AND write (unauthenticated with API key)
    match /faculty_locations/{facultyId} {
      // Allow all reads and writes (for NodeMCU)
      allow read, write: if true;
      
      // Note: This is safe because:
      // 1. NodeMCU uses API key (not public)
      // 2. Only writes to its own faculty document
      // 3. App still enforces approval checks
      // 4. No sensitive data exposed
    }
  }
}
