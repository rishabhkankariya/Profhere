rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        request.auth.uid == userId
        || request.auth.token.email.matches('.*admin.*')
      );
      allow delete: if isSignedIn()
        && request.auth.token.email.matches('.*admin.*');
    }

    // ── Faculty ────────────────────────────────────────────────────────────
    match /faculty/{facultyId} {
      allow read:   if true;
      allow create, delete: if isSignedIn()
        && request.auth.token.email.matches('.*admin.*');
      allow update: if isSignedIn();
    }

    // ── Events ────────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // ── Consultations ──────────────────────────────────────────────────────
    match /consultations/{queueId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false;
    }

    // ── Timetable ──────────────────────────────────────────────────────────
    match /timetable/{entryId} {
      allow read:              if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // ── Subjects ───────────────────────────────────────────────────────────
    match /subjects/{subjectId} {
      allow read:              if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // ── Marks ─────────────────────────────────────────────────────────────
    match /marks/{markId} {
      allow read:              if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // ── Community ─────────────────────────────────────────────────────────
    match /community/{messageId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /community_blocks/{userId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn();
    }

    match /community_restrictions/{userId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn();
    }

    // ── Todos ─────────────────────────────────────────────────────────────
    match /todos/{todoId} {
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.userId;
      allow read, update, delete: if isSignedIn()
        && request.auth.uid == resource.data.userId;
    }

    // ── Cabins ─────────────────────────────────────────────────────────────
    match /cabins/{cabinId} {
      allow read:  if true;
      allow write: if isSignedIn();
    }

    // ── Blocked users ──────────────────────────────────────────────────────
    match /blocked_users/{userId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn();
    }

    // ── Activity logs ──────────────────────────────────────────────────────
    match /activity_logs/{logId} {
      allow read, write: if isSignedIn();
    }

    // ── College students ───────────────────────────────────────────────────
    match /college_students/{docId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn()
        && request.auth.token.email.matches('.*admin.*');
    }

    // ── Class divisions ────────────────────────────────────────────────────
    match /class_divisions/{divisionId} {
      allow read:              if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
  }
}
