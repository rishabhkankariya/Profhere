rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasRole(roleName) {
      // student=0, admin=1, faculty=2  (matches UserRole enum order in Dart)
      let roleMap = {"student": 0, "admin": 1, "faculty": 2};
      return isSignedIn() && userDoc().data.roleIndex == roleMap[roleName];
    }

    function isLegacyAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email.matches('.*admin.*');
    }

    function isAdmin() {
      return hasRole('admin') || isLegacyAdmin();
    }

    function isFaculty() {
      return hasRole('faculty');
    }

    function isStudent() {
      return hasRole('student');
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Own user can update their profile (but not change their role).
      // Admin can update any user doc (e.g. role changes).
      allow update: if isAdmin()
        || (isSignedIn() && request.auth.uid == userId
          && request.resource.data.roleIndex == resource.data.roleIndex);
      allow delete: if false;
    }

    match /faculty/{facultyId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // Admin can update anything.
      // Faculty can update their own status fields only.
      // We match by email (stored in both the faculty doc and the user doc).
      // Both comparisons are lowercased to avoid case mismatch issues.
      allow update: if isAdmin()
        || (isFaculty()
          && resource.data.email.lower() == userDoc().data.email.lower()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'statusIndex',
            'lastUpdated',
            'activeContext',
            'expectedReturnAt',
            'manualOverrideUntil'
          ]));
    }

    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /marks/{markId} {
      allow read: if isAdmin()
        || (isStudent() && (
          resource.data.studentId == request.auth.uid
          || resource.data.studentEmail == request.auth.token.email
          || resource.data.studentName == userDoc().data.name
          || resource.data.studentId == userDoc().data.studentCode
        ));
      allow create, update, delete: if isAdmin();
    }

    match /timetable/{entryId} {
      allow read: if isSignedIn();
      // Admin can do anything. Faculty can manage their own entries only.
      allow create: if isAdmin()
        || (isFaculty() && request.resource.data.facultyId == facultyId);
      allow update, delete: if isAdmin()
        || (isFaculty() && resource.data.facultyId == facultyId);
    }

    match /consultations/{queueId} {
      allow read: if isSignedIn();
      allow create: if isStudent()
        && request.resource.data.studentId == request.auth.uid;
      // Faculty and admin can update (accept/complete). Student can cancel their own.
      allow update: if isAdmin() || isFaculty()
        || (isStudent() && resource.data.studentId == request.auth.uid);
      allow delete: if false;
    }

    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /community/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.senderId == request.auth.uid
        && (
          request.resource.data.channel != 'announcements'
          || isAdmin()
          || isFaculty()
        );
      allow update, delete: if false;
    }

    match /cabins/{cabinId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
